# ignore everything by default
*

# let git traverse folders
!*/

# root control files
!/AGENTS.md
!/.custom
!/.bootstrap/
!/.bootstrap/**
!/package.json
!/.vscode/
!/.vscode/**
!/workspace/
!/workspace/**

# nested repo container stays visible, but its contents are owned by nested repos
!/Repos/
/Repos/**
/worktrees/
/worktrees/**
/.codex/
/.playwright-mcp/
/.restore/
/.restore-backups/
/.repo-archives/

# runtime and generated content
/.DS_Store
/workspace/**/.env
/workspace/**/.env.*
!/workspace/**/.env.example
/workspace/**/.memory/
/workspace/**/.orx/
/workspace/**/.telecodex/
/workspace/**/.pytest_cache/
/workspace/**/__pycache__/
/workspace/**/*.py[cod]
/workspace/**/target/
/workspace/configs/aerospace/engine/node_modules/
/.bootstrap/**/__pycache__/
/.bootstrap/**/*.py[cod]
