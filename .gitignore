# ignore everything by default
*

# let git traverse folders
!*/

# root control files
!/AGENTS.md
!/.custom
!/.codex/
!/.codex/bin/
!/.codex/bin/**
!/.codex/commands/
!/.codex/commands/**
!/.codex/config.toml
!/.codex/docs/
!/.codex/docs/**
!/.codex/manifest.json
!/.codex/rules/
!/.codex/rules/**
!/.codex/skills/
!/.codex/skills/**
!/package.json
!/repos.txt
!/.vscode/
!/.vscode/**
!/workspace/
!/workspace/**

# nested repo container stays visible, but its contents are owned by nested repos
!/Repos/
/Repos/**
/worktrees/
/worktrees/**
/.codex/browser-profiles/
/.codex/local/
/.codex/plugins/
/.codex/proofs/
/.codex/sanitized-mirrors/
/.codex/stitch-runs/
/.codex/tmp/
/.codex/transfer/
/.codex/*.png
/.codex/*.jpg
/.codex/*.jpeg
/.playwright-mcp/
/.restore/
/.restore-backups/
/.repo-archives/

# runtime and generated content
/.DS_Store
/workspace/**/.env
/workspace/**/.env.*
!/workspace/**/.env.example
/workspace/**/.memory/
/workspace/**/.orx/
/workspace/**/.telecodex/
/workspace/**/.pytest_cache/
/workspace/**/__pycache__/
/workspace/**/*.py[cod]
/workspace/**/target/
/workspace/configs/aerospace/engine/node_modules/
/.codex/**/__pycache__/
/.codex/**/*.py[cod]
