# ignore everything by default
*

# let git traverse folders
!*/

# root control files
!/AGENTS.md
!/.custom
!/.bootstrap/
!/.bootstrap/**
!/package.json
!/.vscode/
!/.vscode/**
!/workspace/
!/workspace/**

# nested repo container stays visible, but its contents are owned by nested repos
!/Repos/
/Repos/**
/worktrees/
/worktrees/**
/workspace/orx/
/workspace/telecodex/

# runtime and generated content
/.DS_Store
/workspace/configs/aerospace/engine/node_modules/
/workspace/tmux-codex/.pytest_cache/
/workspace/tmux-codex/.memory/PRD.md
/workspace/tmux-codex/.memory/gates.sh
/workspace/tmux-codex/.memory/runner/
/workspace/tmux-codex/**/__pycache__/
/workspace/tmux-codex/**/*.pyc
