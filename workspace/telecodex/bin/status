#!/bin/bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_common.sh"
parse_profile_args "$@"
if [[ ${#PROFILE_ARGS_REST[@]} -gt 0 ]]; then
  set -- "${PROFILE_ARGS_REST[@]}"
else
  set --
fi
load_env
render_config

echo "profile: $TELECODEX_PROFILE"
echo "label: $APP_LABEL"
echo "health_label: $HEALTH_APP_LABEL"
echo "plist: $PLIST_PATH"
echo "health_plist: $HEALTH_PLIST_PATH"
echo "config: $CONFIG_PATH"
echo "logs: $LOG_DIR"
echo "disabled: $(service_disabled && echo yes || echo no)"
echo "active: $(service_active "$APP_LABEL" && echo yes || echo no)"
echo "lock: $(profile_runtime_lock_state)"
echo "codex: ${CODEX_BINARY}"
echo

if [[ -f "$PLIST_PATH" ]]; then
  echo "launchd:"
  launchctl_print_status "$APP_LABEL"
else
  echo "launchd: plist not installed"
fi

echo
if [[ -f "$HEALTH_PLIST_PATH" ]]; then
  echo "health_launchd:"
  launchctl_print_status "$HEALTH_APP_LABEL"
else
  echo "health_launchd: plist not installed"
fi
