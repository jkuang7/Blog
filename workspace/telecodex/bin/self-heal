#!/bin/bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROFILE="${TELECODEX_PROFILE:-default}"
if [[ "${1:-}" == "--profile" && -n "${2:-}" ]]; then
  PROFILE="$2"
fi

if [[ -f "$REPO_ROOT/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "$REPO_ROOT/.env"
  set +a
fi

profile_key() {
  printf '%s' "$1" | tr '[:lower:]-' '[:upper:]_' | tr -cd 'A-Z0-9_'
}

PROFILE_UPPER="$(profile_key "$PROFILE")"
PROFILE_ROOT="$REPO_ROOT/.telecodex/profiles/$PROFILE"
LOCK_PID="$PROFILE_ROOT/run.lock/pid"
TOKEN_ENV="${PROFILE_UPPER}_TELEGRAM_BOT_TOKEN"
TOKEN_VALUE="${!TOKEN_ENV:-}"
if [[ -z "$TOKEN_VALUE" && "$PROFILE" == "runner" ]]; then
  TOKEN_VALUE="${TELEGRAM_BOT_TOKEN:-}"
fi
if [[ -z "$TOKEN_VALUE" && "$PROFILE" == "default" && "${TELECODEX_ENABLE_DEFAULT:-0}" == "1" ]]; then
  TOKEN_VALUE="${TELEGRAM_BOT_TOKEN:-}"
fi
if [[ -z "$TOKEN_VALUE" ]]; then
  echo "self-heal: profile $PROFILE is not enabled"
  exit 0
fi

if ! curl -fsS "https://api.telegram.org/bot${TOKEN_VALUE}/getMe" >/dev/null; then
  echo "self-heal: Telegram token check failed for profile $PROFILE" >&2
  exit 1
fi

LABEL="dev.jian.telecodex"
if [[ "$PROFILE" != "default" ]]; then
  LABEL="dev.jian.telecodex-$PROFILE"
fi

locked_pid="$(cat "$LOCK_PID" 2>/dev/null || true)"
if [[ -n "$locked_pid" ]] && kill -0 "$locked_pid" >/dev/null 2>&1; then
  echo "self-heal: ok ($PROFILE, pid $locked_pid)"
  exit 0
fi

DOMAIN="gui/$(id -u)"
if launchctl print "$DOMAIN/$LABEL" >/dev/null 2>&1; then
  launchctl kickstart -k "$DOMAIN/$LABEL" >/dev/null 2>&1 || true
fi

echo "self-heal: ok ($PROFILE)"
