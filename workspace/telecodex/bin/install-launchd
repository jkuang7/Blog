#!/bin/bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_common.sh"
parse_profile_args "$@"
if [[ ${#PROFILE_ARGS_REST[@]} -gt 0 ]]; then
  set -- "${PROFILE_ARGS_REST[@]}"
else
  set --
fi

load_env
render_config
build_binary
ensure_dirs
clear_service_disabled

OUT_LOG="$LOG_DIR/telecodex.out.log"
ERR_LOG="$LOG_DIR/telecodex.err.log"
HEALTH_OUT_LOG="$LOG_DIR/telecodex-health.out.log"
HEALTH_ERR_LOG="$LOG_DIR/telecodex-health.err.log"

sed \
  -e "s#__LABEL__#$APP_LABEL#g" \
  -e "s#__REPO_ROOT__#$REPO_ROOT#g" \
  -e "s#__RUN_SCRIPT__#$REPO_ROOT/bin/run-foreground#g" \
  -e "s#__STDOUT_LOG__#$OUT_LOG#g" \
  -e "s#__STDERR_LOG__#$ERR_LOG#g" \
  -e "s#__PATH__#$PATH_DEFAULT#g" \
  -e "s#__HOME__#$HOME#g" \
  -e "s#__PROFILE__#$TELECODEX_PROFILE#g" \
  "$PLIST_TEMPLATE" >"$PLIST_PATH"

launchctl bootout "$(launchctl_domain)/$APP_LABEL" >/dev/null 2>&1 || true
launchctl bootstrap "$(launchctl_domain)" "$PLIST_PATH"
launchctl enable "$(launchctl_domain)/$APP_LABEL"
launchctl kickstart -k "$(launchctl_domain)/$APP_LABEL" >/dev/null 2>&1 || true

sed \
  -e "s#__LABEL__#$HEALTH_APP_LABEL#g" \
  -e "s#__REPO_ROOT__#$REPO_ROOT#g" \
  -e "s#__RUN_SCRIPT__#$REPO_ROOT/bin/self-heal#g" \
  -e "s#__STDOUT_LOG__#$HEALTH_OUT_LOG#g" \
  -e "s#__STDERR_LOG__#$HEALTH_ERR_LOG#g" \
  -e "s#__PATH__#$PATH_DEFAULT#g" \
  -e "s#__HOME__#$HOME#g" \
  -e "s#__PROFILE__#$TELECODEX_PROFILE#g" \
  "$HEALTH_PLIST_TEMPLATE" >"$HEALTH_PLIST_PATH"

launchctl bootout "$(launchctl_domain)/$HEALTH_APP_LABEL" >/dev/null 2>&1 || true
launchctl bootstrap "$(launchctl_domain)" "$HEALTH_PLIST_PATH"
launchctl enable "$(launchctl_domain)/$HEALTH_APP_LABEL"
launchctl kickstart -k "$(launchctl_domain)/$HEALTH_APP_LABEL" >/dev/null 2>&1 || true

echo "Installed LaunchAgent: $PLIST_PATH"
echo "Installed HealthAgent: $HEALTH_PLIST_PATH"
