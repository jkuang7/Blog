#!/bin/bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_common.sh"
parse_profile_args "$@"
if [[ ${#PROFILE_ARGS_REST[@]} -gt 0 ]]; then
  set -- "${PROFILE_ARGS_REST[@]}"
else
  set --
fi

load_env
render_config

echo "profile: $TELECODEX_PROFILE"
echo "repo: $REPO_ROOT"
echo "config: $CONFIG_PATH"
echo "service_loaded: $(service_loaded "$APP_LABEL" && echo yes || echo no)"
echo "service_active: $(service_active "$APP_LABEL" && echo yes || echo no)"
echo "health_service_loaded: $(service_loaded "$HEALTH_APP_LABEL" && echo yes || echo no)"
lock_state="$(profile_runtime_lock_state)"
echo "lock: ${lock_state}"
echo "codex: ${CODEX_BINARY}"
echo "cargo: $(command -v cargo)"
echo "launchctl: $(command -v launchctl)"
if command -v tailscale >/dev/null 2>&1; then
  echo "tailscale: $(command -v tailscale)"
  tailscale status >/dev/null 2>&1 && echo "tailscale_status: connected" || echo "tailscale_status: unavailable"
else
  echo "tailscale: missing"
fi

if service_active "$APP_LABEL" && [[ "$lock_state" != held:* ]]; then
  echo "lock_health: invalid"
  exit 1
fi

"$CODEX_BINARY" --version
telegram_bot_getme >/dev/null
echo "telegram_token: ok"
if telegram_webhook_info | grep -q '"url":""'; then
  echo "webhook: clear"
else
  echo "webhook: configured"
  exit 1
fi
echo "healthcheck: ok"
